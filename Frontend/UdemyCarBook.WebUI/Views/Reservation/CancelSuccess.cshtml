@{
    Layout = null; 
}
<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background-color: #f4f7f6;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px;
            text-align: center;
            max-width: 500px;
        }

        .icon {
            font-size: 60px;
            color: #1089ff;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🚙</div>
        <h2 style="color: #333;">Rezervasyon İptal Edildi</h2>
        <p style="color: #666;">İşleminiz başarıyla tamamlandı. Aracınız sisteme tekrar "Müsait" olarak kaydedilmiştir.</p>
        <a href="/Default/Index" class="btn btn-primary" style="background-color: #1089ff; border: none; border-radius: 50px; padding: 10px 30px;">
            Ana Sayfaya Dön
        </a>
    </div>

    <script>
       
        Swal.fire({
            title: 'Başarılı!',
            text: 'Rezervasyonunuz iptal edildi.',
            icon: 'success',
            confirmButtonColor: '#1089ff'
        });
    </script>
</body>
</html>