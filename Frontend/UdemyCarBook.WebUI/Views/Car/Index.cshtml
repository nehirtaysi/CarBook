@model List<ResultCarPricingWithCarDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UILayout/Index.cshtml";
}

<section class="ftco-section bg-light">
    <div class="container">
        <div class="row">
            @foreach (var item in Model)
            {
                bool hasActiveCampaign = item.IsCampaign && item.CampaignExpiryDate > DateTime.Now;

                <div class="col-md-4">
                    <div class="car-wrap ftco-animate" style="border-radius: 0px !important; background: #fff; margin-bottom: 30px; box-shadow: 0px 5px 15px rgba(0,0,0,0.05); position: relative;">

                        @if (hasActiveCampaign)
                        {
                            <div style="position: absolute; top: 15px; left: 15px; background-color: #e74c3c; color: white; padding: 5px 12px; font-size: 11px; font-weight: bold; z-index: 5; border-radius: 0px; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">
                                FIRSATI KAÇIRMA
                            </div>
                        }

                        <div class="img d-flex align-items-end" style="background-image: url(@item.CoverImageUrl); border-radius: 0px !important; height: 250px;">
                        </div>

                        <div class="text" style="padding: 20px;">
                            <h2 class="mb-0"><a href="#" style=" text-decoration: none; color: #000;">@item.Model</a></h2>

                            <div class="d-flex mb-3 align-items-center">
                                <span class="cat" style="text-transform: uppercase; color: #999;">@item.Brand</span>

                                <div class="price ml-auto text-right">
                                    @if (hasActiveCampaign)
                                    {
                                        <span style="text-decoration: line-through; color: #999; font-size: 13px; display: block; line-height: 1;">
                                            ₺@item.Amount.ToString("N0")
                                        </span>
                                        <span style="color: #e74c3c !important; font-weight: 700; font-size: 20px;">
                                            ₺@item.CampaignPrice?.ToString("N0")
                                        </span>
                                        <div style="font-size: 10px; color: #4a5d23; font-weight: bold; margin-top: 2px;">
                                            <i class="fa fa-clock-o"></i> <span class="countdown-timer" data-date="@item.CampaignExpiryDate?.ToString("yyyy-MM-ddTHH:mm:ss")"></span>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="price mb-0" style="color: #4a5d23 !important; font-weight: 700; font-size: 20px;">
                                            ₺@item.Amount.ToString("N0")
                                        </p>
                                    }
                                    <span style="font-size: 12px; color: #999;">/Günlük</span>
                                </div>
                            </div>

                            <div class="d-flex mb-3" style="font-size: 13px; color: #4a5d23;">
                                <span class="mr-3">@item.Transmission</span>
                                <span>@item.Fuel</span>
                            </div>

                            <p class="d-flex mb-0 d-block">
                                <a href="/Reservation/Index/@item.CarId" class="btn py-3 mr-1"
                                   style="background-color: #4a5d23 !important; color: white !important; border-radius: 0px !important; flex: 1; font-size: 13px; font-weight: bold; border: none; text-align: center;">
                                    HEMEN KİRALA
                                </a>
                                <a href="/Car/CarDetail/@item.CarId" class="btn py-3 ml-1"
                                   style="background-color: #6b8e23 !important; color: white !important; border-radius: 0px !important; flex: 1; font-size: 13px; font-weight: bold; border: none; text-align: center;">
                                    DETAYLAR
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<script>
    function updateCountdowns() {
        document.querySelectorAll('.countdown-timer').forEach(function (timer) {
            var dateAttr = timer.getAttribute('data-date');
            if (!dateAttr) return;

            var expiryDate = new Date(dateAttr).getTime();
            var now = new Date().getTime();
            var distance = expiryDate - now;

            if (distance < 0) {
                timer.innerHTML = "Süre Doldu";
                return;
            }

            var days = Math.floor(distance / (1000 * 60 * 60 * 24));
            var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            var seconds = Math.floor((distance % (1000 * 60)) / 1000);

            timer.innerHTML = (days > 0 ? days + "g " : "") + hours + "s " + minutes + "d " + seconds + "sn";
        });
    }
    setInterval(updateCountdowns, 1000);
    updateCountdowns();
</script>