@model UdemyCarBook.Dto.LoginDtos.CreateLoginDto

@{
    Layout = null; // Giriş sayfası için kendi layoutunu kullanacak
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <title>CarBook - Giriş Yap</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta content="CarBook Giriş Sayfası" name="description" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <link rel="shortcut icon" href="~/Admin/vertical/assets/images/favicon.ico">

    <link href="~/Admin/vertical/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Admin/vertical/assets/css/theme.min.css" rel="stylesheet" type="text/css" />

    <style>
        /* KURUMSAL HAKİ YEŞİL AYARLARI (DEĞİŞMEDİ) */
        :root {
            --carbook-green: #6b8e23; /* Haki Yeşil */
            --dark-green: #4a5d23;
        }

        body {
            background-color: #f4f7f6;
        }

        .text-carbook {
            color: var(--carbook-green) !important; /* Sağdaki form logosu */
        }

        .btn-carbook {
            background-color: var(--carbook-green) !important;
            border-color: var(--carbook-green) !important;
            color: white !important;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 12px;
            border-radius: 5px;
            transition: 0.3s ease;
        }

            .btn-carbook:hover {
                background-color: var(--dark-green) !important;
                box-shadow: 0px 5px 15px rgba(107, 142, 35, 0.3);
            }

        .form-control-user {
            border-radius: 5px;
            padding: 24px 15px;
            border: 1px solid #e1e1e1;
            font-size: 14px;
        }

            .form-control-user:focus {
                border-color: var(--carbook-green);
                box-shadow: 0 0 0 0.2rem rgba(107, 142, 35, 0.15);
            }

        .social-list-item:hover {
            background-color: var(--carbook-green) !important;
            color: white !important;
            border-color: var(--carbook-green) !important;
        }

        /* GÖRSEL ÜZERİNDEKİ YAZILAR VE İKON (DEĞİŞMEDİ) */
        .login-sidebar-content h2 {
            font-size: 3rem;
            font-weight: 800;
            color: white !important;
            margin-bottom: 15px;
        }

        .login-sidebar-content p {
            font-size: 1.3rem;
            color: rgba(255,255,255,0.8) !important;
            max-width: 300px;
            margin: 0 auto;
        }

        /* 1. SADECE FOTOĞRAF ÜZERİNDEKİ YEŞİLİN ŞEFFAFLIĞINI (TRANSPARANLIĞINI) ARTIRAN KISIM */
        .bg-login {
            /* ESKİ DEĞER: (rgba(107, 142, 35, 0.75), rgba(42, 59, 13, 0.9)) -> Yoğun Yeşildi.
                   YENİ DEĞER: (rgba(107, 142, 35, 0.3), rgba(42, 59, 13, 0.45)) -> Çok daha şeffaf (transparan).
                */
            background-image: linear-gradient(rgba(107, 142, 35, 0.3), rgba(42, 59, 13, 0.45)), url('https://i.pinimg.com/736x/37/ac/3f/37ac3f68c9335c7cca03bd30c63e3107.jpg');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            padding: 40px;
        }
    </style>
</head>

<body>

    <div>
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex align-items-center min-vh-100">
                        <div class="w-100 d-block bg-white shadow-lg rounded my-5">
                            <div class="row no-gutters">

                                <div class="col-lg-5 d-none d-lg-flex bg-login rounded-left">
                                    <div class="login-sidebar-content">
                                      
                                        <p>Araç Kiralamanın En İyi Yolu</p>
                                        <div class="mt-4">
                                            <i class="mdi mdi-steering mdi-48px"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-7">
                                    <div class="p-5">
                                        <div class="text-center mb-4">
                                            <a href="/Default/Index/" class="text-dark font-size-22 font-family-secondary">
                                                <i class="mdi mdi-car-convertible text-carbook"></i> <b>CarBook</b>
                                            </a>
                                        </div>

                                        <h1 class="h5 mb-1">Tekrar Hoş Geldin!</h1>
                                        <p class="text-muted mb-4">Lütfen giriş bilgilerinizi kontrol ediniz.</p>

                                        <form class="user" method="post">
                                            <input type="hidden" name="ReturnUrl" value="@Context.Request.Query["ReturnUrl"]" />
                                            <div class="form-group">
                                                <input type="text" class="form-control form-control-user" placeholder="Kullanıcı Adınız" asp-for="Username" required>
                                            </div>
                                            <div class="form-group">
                                                <input type="password" class="form-control form-control-user" placeholder="Şifreniz" asp-for="Password" required>
                                            </div>

                                            <button type="submit" class="btn btn-carbook btn-block waves-effect waves-light">
                                                <i class="mdi mdi-login mr-1"></i> Sisteme Giriş Yap
                                            </button>
                                        </form>

                                        <div class="text-center mt-4">
                                            <h5 class="text-muted font-size-14">Sosyal Medya Hesaplarımız</h5>
                                            <ul class="list-inline mt-3 mb-0">
                                                <li class="list-inline-item">
                                                    <a href="javascript: void(0);" class="social-list-item border-primary text-primary"><i class="mdi mdi-facebook"></i></a>
                                                </li>
                                                <li class="list-inline-item">
                                                    <a href="javascript: void(0);" class="social-list-item border-danger text-danger"><i class="mdi mdi-google"></i></a>
                                                </li>
                                                <li class="list-inline-item">
                                                    <a href="javascript: void(0);" class="social-list-item border-info text-info"><i class="mdi mdi-twitter"></i></a>
                                                </li>
                                            </ul>
                                        </div>

                                        <div class="row mt-5">
                                            <div class="col-12 text-center">
                                                <p class="text-muted mb-2">
                                                    <a href="/Login/ForgotPassword/" class="text-muted font-weight-medium ml-1">Şifrenizi mi Unuttunuz?</a>
                                                </p>
                                                <p class="text-muted mb-0">
                                                    Bir hesabınız yok mu?
                                                    <a href="/Register/CreateAppUser/" class="text-carbook font-weight-bold ml-1">
                                                        Hemen Hesap Oluştur
                                                    </a>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/Admin/vertical/assets/js/jquery.min.js"></script>
    <script src="~/Admin/vertical/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/vertical/assets/js/metismenu.min.js"></script>
    <script src="~/Admin/vertical/assets/js/waves.js"></script>
    <script src="~/Admin/vertical/assets/js/simplebar.min.js"></script>
    <script src="~/Admin/vertical/assets/js/theme.js"></script>

</body>
</html>