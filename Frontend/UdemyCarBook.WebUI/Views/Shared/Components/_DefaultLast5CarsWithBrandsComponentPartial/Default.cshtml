@model List<ResultLast5CarsWithBrandsDto>

<section class="ftco-section ftco-no-pt bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-12 heading-section text-center ftco-animate mb-5">
                <span class="subheading" style="color: #6b8e23 !important;">Sizin İçin Önerilerimiz</span>
                <h2 class="mb-2">Öne Çıkan Araçlarımız</h2>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="carousel-car owl-carousel">
                    @foreach (var item in Model)
                    {
                        bool hasActiveCampaign = item.IsCampaign && item.CampaignExpiryDate > DateTime.Now;

                        <div class="item">
                            <div class="car-wrap ftco-animate" style="border-radius: 0px !important; position: relative;">

                                @if (hasActiveCampaign)
                                {
                                    <div style="position: absolute; top: 10px; left: 10px; background-color: #e74c3c; color: white; padding: 3px 10px; font-size: 11px; font-weight: bold; z-index: 5; border-radius: 2px;">
                                        FIRSAT ARACI
                                    </div>
                                }

                                <div class="img d-flex align-items-end" style="background-image: url(@item.CoverImageUrl); border-radius: 0px !important;">
                                </div>
                                <div class="text">
                                    <h2 class="mb-0"><a href="#" style="color: #000;">@item.Model</a></h2>
                                    <div class="d-flex mb-3 align-items-center">
                                        <span class="cat" style="color:#999">@item.BrandName</span>

                                        <div class="price ml-auto text-right">
                                            @if (hasActiveCampaign)
                                            {
                                                <span style="text-decoration: line-through; color: #999; font-size: 12px; display: block; line-height: 1;">
                                                    ₺@item.Amount.ToString("N0")
                                                </span>
                                                <span style="color: #e74c3c !important; font-weight: 600; font-size: 20px;">
                                                    ₺@item.CampaignPrice?.ToString("N0")
                                                </span>
                                                <div style="font-size: 10px; color: #4a5d23; font-weight: bold; margin-top: 2px;">
                                                    <i class="fa fa-clock-o"></i> <span class="countdown-timer" data-date="@item.CampaignExpiryDate?.ToString("yyyy-MM-ddTHH:mm:ss")"></span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span style="color: #4a5d23 !important; font-weight: 400; font-size: 18px;">
                                                    ₺@item.Amount.ToString("N0")
                                                </span>
                                            }
                                            <span style="color: #999; font-size: 12px;">/Günlük</span>
                                        </div>
                                    </div>

                                    <div class="d-flex mb-3" style="font-size: 13px; color: #4a5d23;">
                                        <span class="mr-3">@item.Transmission</span>
                                        <span>@item.Fuel</span>
                                    </div>

                                    <p class="d-flex mb-0 d-block">
                                        <a href="/Reservation/Index/@item.CarID"
                                                                 class="btn py-2 mr-1"
                                                                 onmouseover="this.style.setProperty('background-color', '#6b8e23', 'important')"
                                                                 onmouseout="this.style.setProperty('background-color', '#4a5d23', 'important')"
                                                                 style="background-color: #4a5d23 !important; color: white !important; border-radius: 0px !important; flex: 1; border: none !important; transition: 0.3s; font-weight: bold; text-align: center;">
                                            Aracı Kirala
                                        </a>

                                        <a href="/Car/CarDetail/@item.CarID"
                                                                 class="btn py-2 ml-1"
                                                                 onmouseover="this.style.setProperty('background-color', '#4a5d23', 'important')"
                                                                 onmouseout="this.style.setProperty('background-color', '#6b8e23', 'important')"
                                                                 style="background-color: #6b8e23 !important; color: white !important; border-radius: 0px !important; flex: 1; border: none !important; transition: 0.3s; font-weight: bold; text-align: center;">
                                            Detaylar
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function updateCountdowns() {
        document.querySelectorAll('.countdown-timer').forEach(function (timer) {
            var dateAttr = timer.getAttribute('data-date');
            if (!dateAttr) return;

            var expiryDate = new Date(dateAttr).getTime();
            var now = new Date().getTime();
            var distance = expiryDate - now;

            if (distance < 0) {
                timer.innerHTML = "Süre Doldu";
                return;
            }

            var days = Math.floor(distance / (1000 * 60 * 60 * 24));
            var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            var seconds = Math.floor((distance % (1000 * 60)) / 1000);

            timer.innerHTML = (days > 0 ? days + "g " : "") + hours + "s " + minutes + "d " + seconds + "sn";
        });
    }

    setInterval(updateCountdowns, 1000);
    updateCountdowns();
</script> 