@model List<ResultServiceDto>

<section class="ftco-section" style="background-color: white !important; padding: 100px 0;">
    <div class="container">
        <div class="row justify-content-center mb-5">
            <div class="col-md-7 text-center heading-section ftco-animate">
                <span class="subheading" style="color: #6b8e23 !important; font-weight: bold; text-transform: uppercase; letter-spacing: 2px;">Hizmetler</span>
                <h2 class="mb-3" style="color: #4a5d23 !important; font-weight: bold;">Sizin İçin Hizmetlerimiz</h2>
            </div>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-3 mb-4">
                        <div class="services services-2 w-100 text-center" style="background: none !important;">

                            <div class="icon d-flex align-items-center justify-content-center"
                                 style="background-color: #4a5d23 !important; border-radius: 0px !important; width: 80px; height: 80px; margin: 0 auto 20px auto; transition: 0.3s;"
                                 onmouseover="this.style.backgroundColor='#6b8e23'"
                                 onmouseout="this.style.backgroundColor='#4a5d23'">
                                <span class="@item.IconUrl" style="color: white !important; font-size: 30px;"></span>
                            </div>

                            <div class="text w-100">
                                <h3 class="heading mb-2" style="color: #4a5d23 !important; font-weight: bold; font-size: 20px;">@item.Title</h3>
                                <p style="color: #666; font-size: 15px; line-height: 1.6;">@item.Description</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-md-12 text-center">
                    <p>Hizmetlerimiz şu an güncelleniyor...</p>
                </div>
            }
        </div>
    </div>
</section>
