<script>
    $(document).ready(function () {
        $('input[name="time_off"]').attr('id', 'time_off');

        var pickerOptions = {
            format: 'dd/mm/yyyy', 
            startDate: new Date(), 
            autoclose: true,
            todayHighlight: true,
            orientation: "bottom auto"
        };

        $('#book_pick_date, #book_off_date').datepicker('remove');
        $('#book_pick_date').datepicker(pickerOptions);
        $('#book_off_date').datepicker(pickerOptions);

        $('#book_pick_date').on('changeDate', function (e) {
            if (e.date) {
                var nextDay = new Date(e.date);
                nextDay.setDate(nextDay.getDate() + 1);

                $('#book_off_date').datepicker('setStartDate', e.date);
                $('#book_off_date').datepicker('update', nextDay);
            }
        });

        $('#time_pick, #time_off').timepicker('remove');
        $('#time_pick, #time_off').timepicker({
            'timeFormat': 'H:i', 
            'step': 30,
            'scrollDefault': 'now'
        });

       
        $('#book_pick_date, #book_off_date').on('change', function() {
            var val = $(this).val();
            
        });
    });
</script>