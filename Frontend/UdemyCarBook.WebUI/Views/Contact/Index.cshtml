@model CreateContactDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UILayout/Index.cshtml";
}

<style>
    /* 1. TÜM BAŞLIKLARI VE METİNLERİ AYNI KOYU TONA ZORLA */
    .contact-info p,
    .contact-info p a,
    .contact-info p span,
    .contact-info a {
        color: #000 !important; /* Hepsini önce tam siyah yapıyoruz */
        text-decoration: none !important; /* Alt çizgiyi kaldır */
        font-size: 15px !important;
        font-weight: 500 !important; /* Ne çok kalın ne çok ince */
        line-height: 1.4 !important;
    }

    /* 2. SADECE ALT BİLGİLERİ (ADRESİN DEVAMI VS.) HAFİF GRİ YAPMAK İSTERSEN */
    /* Ama şu an senin istediğin 'hepsi aynı ton olsun' olduğu için burayı siyah bıraktık */

    /* 3. İKONLAR (HAKİ) */
    .contact-info .icon {
        background: transparent !important;
        width: 30px !important;
        height: 30px !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        margin: 5px 15px 0 0 !important;
        flex-shrink: 0 !important;
    }

        .contact-info .icon span {
            color: #4a5d23 !important;
            font-size: 20px !important;
        }

    /* 4. GENEL HİZALAMA */
    .contact-info .col-md-3 {
        display: flex !important;
        align-items: flex-start !important;
        margin-bottom: 30px !important;
    }

    .contact-info .align-self-stretch {
        display: flex !important;
        flex-direction: row !important;
        background: transparent !important;
        padding: 0 !important;
    }

    /* 5. FORM BUTONU VE INPUTLAR */
    .contact-form .btn-primary {
        background-color: #4a5d23 !important;
        border: none !important;
        border-radius: 0px !important;
        padding: 15px !important;
    }

    .contact-form .form-control {
        border-radius: 0px !important;
    }
</style>

<section class="ftco-section contact-section">
    <div class="container">
        <div class="row d-flex mb-5 contact-info">

            @await Component.InvokeAsync("_FooterAddressComponentPartial")

            <div class="col-md-8 block-9 mb-md-5">
                <form class="bg-light p-5 contact-form" method="post" style="border-radius: 0px !important;">
                    <div class="form-group">
                        <input type="text" class="form-control" placeholder="Adınız Soyadınız" asp-for="Name">
                    </div>
                    <div class="form-group">
                        <input type="email" class="form-control" placeholder="Email Adresiniz" asp-for="Email">
                    </div>
                    <div class="form-group">
                        <input type="text" class="form-control" placeholder="Konu" asp-for="Subject">
                    </div>
                    <div class="form-group">
                        <textarea id="" cols="30" rows="7" class="form-control" placeholder="Mesajınız" asp-for="Message"></textarea>
                    </div>
                    <div class="form-group">
                        <input type="submit" value="Mesajı Gönder" class="btn btn-primary">
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="row no-gutters">
        <div class="col-md-12 text-center mb-5">
            @* Harita Alanı - Renkli ve Küçültülmüş *@
            <div style="display: inline-block; width: 80%; height: 350px; border: 5px solid #fff; box-shadow: 0px 10px 30px rgba(0,0,0,0.1); border-radius: 15px; overflow: hidden;">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d192698.6332849544!2d28.871753!3d41.005321!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa7040068086b%3A0xe1cc1e01f57f753!2zxLBzdGFuYnVs!5e0!3m2!1str!2str!4v1711680000000!5m2!1str!2str"
                        width="100%"
                        height="100%"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>
    </div>
</section>